{
  "name": "google-calendar-tonton",
  "version": "1.4.0",
  "description": "Auto-send Tonton’s schedule from Google Calendar.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check": "oxlint ./src && oxfmt --check ./src",
    "check:write": "oxlint --fix ./src && oxfmt --write ./src",
    "format": "oxfmt --check ./src",
    "format:write": "oxfmt --write ./src",
    "lint": "oxlint ./src",
    "lint:fix": "oxlint --fix ./src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["google-calendar", "chrome-extension"],
  "author": "minagishl",
  "license": "MIT",
  "devDependencies": {
    "@crxjs/vite-plugin": "2.4.0",
    "@types/chrome": "0.1.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-react": "^6.0.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "terser": "^5.46.1",
    "typescript": "6.0.2",
    "vite": "8.0.7"
  },
  "dependencies": {
    "ical.js": "^2.2.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "webextension-polyfill": "^0.12.0"
  }
}
